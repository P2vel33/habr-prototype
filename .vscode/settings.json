{
    "i18n-ally.localesPaths": ["public/locales", "src/shared/config/i18n"],
    // ... другие настройки ...
    "stylelint.validate": ["css", "postcss", "scss"],
    "editor.defaultFormatter": "esbenp.prettier-vscode", // Указывает Prettier как форматтер по умолчанию
    "editor.formatOnSave": true, // Форматировать при сохранении
    "[javascript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[javascriptreact]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[typescript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[typescriptreact]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[json]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[jsonc]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[yaml]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[markdown]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[scss]": {
        "editor.defaultFormatter": "stylelint.vscode-stylelint" // Убедитесь, что установлено расширение Stylelint
    },
    // Альтернатива: использовать ESLint как форматтер (он будет запускать Prettier через eslint-plugin-prettier)
    // "editor.defaultFormatter": "dbaeumer.vscode-eslint",
    // "[javascript]": {
    //   "editor.defaultFormatter": "dbaeumer.vscode-eslint"
    // },
    // "[javascriptreact]": {
    //   "editor.defaultFormatter": "dbaeumer.vscode-eslint"
    // },
    // "[typescript]": {
    //   "editor.defaultFormatter": "dbaeumer.vscode-eslint"
    // },
    // "[typescriptreact]": {
    //   "editor.defaultFormatter": "dbaeumer.vscode-eslint"
    // },
    "eslint.validate": [
        "javascript",
        "javascriptreact",
        "typescript",
        "typescriptreact",
        "html"
        // "scss"
    ],
    "editor.codeActionsOnSave": {
        "source.fixAll.eslint": "explicit", // Автоматически исправлять ошибки ESLint (включая prettier через плагин) при сохранении
        "source.fixAll.stylelint": "explicit",
        "source.organizeImports": "never" // Опционально: отключить автоимпорт, если он мешает
    }
}
